---
import Layout from '../layouts/Layout.astro';
import pages from '../data/programmatic-pages.json';

export function getStaticPaths() {
  return pages.map(p => ({
    params: { slug: p.slug },
    props: p
  }));
}

const { slug, verb, displayVerb, displayAction, contentType, h1, desc } = Astro.props;

// Related pages (same verb)
const related = pages.filter(p => p.verb === verb && p.slug !== slug).slice(0, 6);

const icon = { humanize:'🤖', rewrite:'✏️', paraphrase:'🔄', improve:'⬆️', polish:'✨', summarize:'📝', expand:'🔍', shorten:'✂️', formalize:'👔', simplify:'📖' }[verb] || '🛠️';

const useCases = [
  `You just used AI to generate ${contentType.toLowerCase()} content and need to make it sound natural.`,
  `Your ${contentType.toLowerCase()} needs to pass AI detection tools like GPTZero or Turnitin.`,
  `You want to improve the readability and flow of your ${contentType.toLowerCase()}.`,
];
---

<Layout title={`${h1} | CleverWrite`} description={desc} canonical={`/${slug}`}>
  <main class="container section-block" style="padding-top:var(--space-3)">
    <!-- Breadcrumb -->
    <nav class="breadcrumbs">
      <a href="/">Home</a>
      <span>/</span>
      <a href="/tools">{displayVerb}</a>
      <span>/</span>
      <span>{contentType}</span>
    </nav>

    <!-- H1 -->
    <h1 style="margin-bottom:var(--space-1)">{icon} {h1}</h1>
    <p style="color:var(--text-muted);font-size:var(--text-sm);margin-bottom:var(--space-3)">{desc}</p>

    <!-- Tool Panel -->
    <div class="tool-panel">
      <div class="flex items-center gap-1" style="margin-bottom:var(--space-2)">
        <span class="tag">{displayVerb}</span>
        <span style="font-size:var(--text-xs);color:var(--text-muted)">{contentType}</span>
      </div>
      <textarea id="inputText" class="text-input" style="min-height:200px" placeholder={`Paste your ${contentType.toLowerCase()} here...`}></textarea>
      <div class="flex justify-between items-center mt-2">
        <span class="char-count" style="font-size:var(--text-xs);color:var(--text-muted)">0 / 5000</span>
        <button id="actionBtn" data-verb={verb} class="btn-primary">{icon} {displayAction} This {contentType}</button>
      </div>
      <div id="resultArea" class="mt-3 hidden">
        <h3 style="font-size:var(--text-sm);font-weight:600;margin-bottom:var(--space-1)">Result</h3>
        <div id="resultText" class="result-box"></div>
        <div class="flex gap-1 mt-2">
          <button id="copyBtn" class="btn-secondary">📋 Copy</button>
          <span id="statusBadge" class="stat-badge success hidden">✅ Done</span>
        </div>
      </div>
    </div>

    <!-- Use Cases -->
    <div class="card section-block" style="padding:var(--space-3)">
      <h3 style="margin-bottom:var(--space-2)">When to Use This Tool</h3>
      <ul style="font-size:var(--text-sm);color:var(--text-muted);line-height:var(--leading-base);padding-left:var(--space-2)">
        {useCases.map(c => <li style="margin-bottom:var(--space-1)">{c}</li>)}
      </ul>
    </div>

    <!-- FAQ -->
    <div class="card section-block" style="padding:var(--space-3)">
      <h3 style="margin-bottom:var(--space-2)">FAQ</h3>
      <div class="faq-item">
        <div class="faq-q">How does this {displayVerb.toLowerCase()} tool work?</div>
        <div class="faq-a">Paste your text and click "{displayAction} This {contentType}". Our AI analyzes and processes it, returning the result instantly.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">Is it free to use?</div>
        <div class="faq-a">Yes, completely free. No registration or credit card required. Up to 5,000 characters per request.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">What's the difference between {displayVerb.toLowerCase()} and other tools?</div>
        <div class="faq-a">Each tool specializes in a specific writing action. {displayVerb} focuses on {verb === 'humanize' ? 'making text sound natural and human-like' : verb === 'rewrite' ? 'completely rewording your text' : verb === 'paraphrase' ? 'rephrasing while keeping meaning identical' : verb === 'summarize' ? 'condensing to key points' : verb === 'improve' ? 'enhancing clarity and flow' : verb === 'expand' ? 'adding depth and detail' : verb === 'shorten' ? 'making text more concise' : verb === 'polish' ? 'fixing grammar and style' : verb === 'formalize' ? 'making text more professional' : 'making text easier to understand'}.</div>
      </div>
    </div>

    <!-- Related -->
    <section class="section-block">
      <h3 style="margin-bottom:var(--space-2)">Related {displayVerb} Tools</h3>
      <div class="grid-3">
        {related.map(p => (
          <a href={`/${p.slug}`} class="tool-link-card">{p.displayVerb} {p.contentType}</a>
        ))}
      </div>
    </section>
  </main>
</Layout>

<script>
  const btn = document.getElementById('actionBtn');
  const textarea = document.getElementById('inputText');
  const resultArea = document.getElementById('resultArea');
  const resultText = document.getElementById('resultText');
  const copyBtn = document.getElementById('copyBtn');
  const statusBadge = document.getElementById('statusBadge');
  const charCount = document.querySelector('.char-count');
  let isLoading = false;
  const verb = btn?.getAttribute('data-verb') || 'rewrite';

  btn?.addEventListener('click', async () => {
    const text = textarea?.value.trim();
    if (!text || isLoading) return;
    isLoading = true;
    btn.disabled = true;
    btn.textContent = '⏳ Processing...';
    resultArea?.classList.add('hidden');
    statusBadge?.classList.add('hidden');
    try {
      const res = await fetch('/api/tool', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text, verb })
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'API error');
      resultText.textContent = data.result;
      resultArea?.classList.remove('hidden');
      statusBadge.textContent = '✅ Done';
      statusBadge.className = 'stat-badge success';
      statusBadge.classList.remove('hidden');
    } catch (err) {
      resultText.textContent = 'Error: ' + err.message;
      resultArea?.classList.remove('hidden');
      statusBadge.textContent = '⚠️ Error';
      statusBadge.className = 'stat-badge error';
      statusBadge.classList.remove('hidden');
    } finally {
      isLoading = false;
      btn.disabled = false;
      btn.textContent = btn.textContent.replace('⏳', verb === 'humanize' ? '🤖' : '✨');
    }
  });

  copyBtn?.addEventListener('click', async () => {
    const text = resultText?.textContent;
    if (text) {
      try { await navigator.clipboard.writeText(text); copyBtn.textContent = '✅ Copied!'; setTimeout(() => { copyBtn.textContent = '📋 Copy'; }, 2000); }
      catch { const ta = document.createElement('textarea'); ta.value = text; document.body.appendChild(ta); ta.select(); document.execCommand('copy'); document.body.removeChild(ta); copyBtn.textContent = '✅ Copied!'; setTimeout(() => { copyBtn.textContent = '📋 Copy'; }, 2000); }
    }
  });

  textarea?.addEventListener('input', function() { charCount.textContent = this.value.length + ' / 5000'; });
</script>
