---
import Layout from '../layouts/Layout.astro';
import pages from '../data/programmatic-pages.json';

export function getStaticPaths() {
  return pages.map(p => ({
    params: { slug: p.slug },
    props: p
  }));
}

const { slug, verb, displayVerb, displayAction, contentType, h1, desc, keywords } = Astro.props;

// Get related pages (same verb, different types)
const relatedSameVerb = pages
  .filter(p => p.verb === verb && p.slug !== slug)
  .slice(0, 6);

// Get related pages (same content type, different verbs)
const relatedSameType = pages
  .filter(p => p.contentType === contentType && p.verb !== verb)
  .slice(0, 4);

const kws = keywords.split(',').map(k => k.trim());
const kwString = kws.join(', ');
const icon = {
  humanize: '🤖',
  rewrite: '✏️',
  paraphrase: '🔄',
  improve: '⬆️',
  polish: '✨',
  summarize: '📝',
  expand: '🔍',
  shorten: '✂️',
  formalize: '👔',
  simplify: '📖'
}[verb] || '🛠️';

const actionLabel = `${displayAction} This ${contentType}`;
const placeholderText = `Paste your ${contentType.toLowerCase()} here...`;
const resultLabel = `${displayVerb}ed ${contentType}`;
const metaTitle = `${h1} | CleverWrite — Free AI Writing Toolkit`;
---

<Layout title={metaTitle} canonical={`/${slug}`} metaDesc={desc} metaKeywords={kwString}>
  <main class="max-w-3xl mx-auto px-4 py-12">
    <!-- SEO Content -->
    <article class="mb-8">
      <div class="flex items-center gap-2 mb-2">
        <span class="text-2xl">{icon}</span>
        <span class="text-sm text-gray-400 uppercase tracking-wide">{displayVerb}</span>
      </div>
      <h1 class="text-3xl font-bold mb-2">{h1}</h1>
      <p class="text-gray-600">{desc}</p>
    </article>

    <!-- Tool Interface -->
    <section class="bg-white rounded-xl shadow-lg p-6 mb-8">
      <div class="flex items-center gap-2 mb-4">
        <span class="bg-blue-100 text-blue-700 text-xs font-medium px-2.5 py-0.5 rounded">Free Tool</span>
        <span class="text-sm text-gray-400">{contentType}</span>
      </div>

      <textarea
        id="inputText"
        class="w-full h-48 border border-gray-300 rounded-lg p-4 text-base focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"
        placeholder={placeholderText}
      ></textarea>

      <div class="flex justify-between items-center mt-4">
        <span class="text-sm text-gray-400 char-count">0 / 5000 characters</span>
        <button id="actionBtn" data-verb={verb} class="bg-blue-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-blue-700 transition disabled:opacity-50">
          {icon} {actionLabel}
        </button>
      </div>

      <div id="resultArea" class="mt-6 hidden">
        <h3 class="font-semibold mb-2">{resultLabel}</h3>
        <div id="resultText" class="bg-gray-50 border rounded-lg p-4 min-h-[100px] whitespace-pre-wrap"></div>
        <div class="flex gap-3 mt-3">
          <button id="copyBtn" class="bg-gray-200 px-4 py-2 rounded-lg hover:bg-gray-300 transition">📋 Copy</button>
          <span id="statusBadge" class="inline-flex items-center gap-1 text-green-600 text-sm">✅ Done</span>
        </div>
      </div>
    </section>

    <!-- Related: Same Verb -->
    <section class="border-t pt-8 mb-8">
      <h2 class="text-xl font-semibold mb-4">More {displayVerb} Tools</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
        {relatedSameVerb.map(p => (
          <a href={`/${p.slug}`} class="block p-3 border rounded-lg hover:bg-gray-50 transition text-sm">
            {p.displayVerb} {p.contentType}
          </a>
        ))}
      </div>
    </section>

    <!-- Related: Same Type -->
    {relatedSameType.length > 0 && (
    <section class="border-t pt-8 mb-8">
      <h2 class="text-xl font-semibold mb-4">More Ways to Process {contentType}</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
        {relatedSameType.map(p => (
          <a href={`/${p.slug}`} class="block p-3 border rounded-lg hover:bg-gray-50 transition text-sm">
            {p.displayVerb} {p.contentType}
          </a>
        ))}
      </div>
    </section>
    )}

    <!-- Home link -->
    <div class="text-center border-t pt-8">
      <a href="/" class="text-blue-600 hover:underline">← Back to All Tools</a>
    </div>
  </main>
</Layout>

<script>
  const btn = document.getElementById('actionBtn');
  const textarea = document.getElementById('inputText');
  const resultArea = document.getElementById('resultArea');
  const resultText = document.getElementById('resultText');
  const copyBtn = document.getElementById('copyBtn');
  const statusBadge = document.getElementById('statusBadge');
  const charCount = document.querySelector('.char-count');
  let isLoading = false;
  const verb = document.getElementById('actionBtn')?.getAttribute('data-verb') || 'rewrite';

  btn?.addEventListener('click', async () => {
    const text = textarea?.value.trim();
    if (!text || isLoading) return;

    isLoading = true;
    btn.disabled = true;
    btn.textContent = '⏳ Processing...';
    resultArea?.classList.add('hidden');

    try {
      const res = await fetch('/api/tool', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text, verb })
      });

      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'API error');

      resultText.textContent = data.result;
      resultArea?.classList.remove('hidden');
      copyBtn.textContent = '📋 Copy';
      statusBadge.textContent = '✅ Done';
      statusBadge.className = 'inline-flex items-center gap-1 text-green-600 text-sm';
    } catch (err) {
      resultText.textContent = 'Error: ' + err.message + '\n\nPlease try again.';
      resultArea?.classList.remove('hidden');
      statusBadge.textContent = '⚠️ Error';
      statusBadge.className = 'inline-flex items-center gap-1 text-red-600 text-sm';
    } finally {
      isLoading = false;
      btn.disabled = false;
      btn.textContent = btn.textContent.replace('⏳', verb === 'humanize' ? '🤖' : '✨');
    }
  });

  copyBtn?.addEventListener('click', async () => {
    const text = resultText?.textContent;
    if (text) {
      try {
        await navigator.clipboard.writeText(text);
        copyBtn.textContent = '✅ Copied!';
        setTimeout(() => { copyBtn.textContent = '📋 Copy'; }, 2000);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = text;
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        copyBtn.textContent = '✅ Copied!';
        setTimeout(() => { copyBtn.textContent = '📋 Copy'; }, 2000);
      }
    }
  });

  textarea?.addEventListener('input', function() {
    charCount.textContent = this.value.length + ' / 5000 characters';
  });
</script>
