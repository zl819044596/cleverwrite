---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found | CleverWrite" description="The page you're looking for doesn't exist.">
  <main class="container" style="text-align: center; padding: 80px 16px;">
    <h1 style="font-size: 64px; margin-bottom: 8px; color: var(--color-primary);">404</h1>
    <h2 style="margin-bottom: 16px;">Page Not Found</h2>
    <p style="color: var(--text-muted); margin-bottom: 32px; max-width: 400px; margin-left: auto; margin-right: auto;">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <a href="/" class="btn-primary" style="text-decoration: none;">← Back to Home</a>
  </main>
</Layout>
