---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pricing — CleverWrite" description="Choose the right plan for your writing needs. Free and Pro plans available." canonical="/pricing/">
  <main class="container section-block" style="padding-top:var(--space-4);padding-bottom:var(--space-5)">
    <h1 class="section-title" style="text-align:center;margin-bottom:var(--space-1)">Simple Pricing</h1>
    <p style="text-align:center;color:var(--text-muted);margin-bottom:var(--space-4);font-size:var(--text-sm)">Start free. Upgrade when you need more.</p>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:var(--space-3);max-width:700px;margin:0 auto">
      <!-- Free Plan -->
      <div class="card" style="padding:var(--space-3);text-align:center">
        <h2 style="font-size:var(--text-lg);margin-bottom:var(--space-1)">Free</h2>
        <p style="font-size:var(--text-2xl);font-weight:700;color:var(--text-title);margin-bottom:var(--space-2)">$0</p>
        <ul style="list-style:none;padding:0;font-size:var(--text-sm);color:var(--text-muted);margin-bottom:var(--space-3)">
          <li style="padding:6px 0">✅ 3 uses per day</li>
          <li style="padding:6px 0">✅ 5,000 chars per request</li>
          <li style="padding:6px 0">✅ All tools included</li>
          <li style="padding:6px 0">✅ No signup required</li>
        </ul>
        <span class="btn-primary" style="opacity:0.6;cursor:default">Current Plan</span>
      </div>

      <!-- Pro Plan -->
      <div class="card" style="padding:var(--space-3);text-align:center;border-color:var(--color-primary);position:relative">
        <span class="pro-badge" style="position:absolute;top:-8px;right:12px;font-size:11px;padding:2px 10px">Popular</span>
        <h2 style="font-size:var(--text-lg);margin-bottom:var(--space-1)">Pro</h2>
        <p style="font-size:var(--text-2xl);font-weight:700;color:var(--text-title);margin-bottom:var(--space-2)">$9.99<span style="font-size:var(--text-sm);font-weight:400;color:var(--text-muted)">/month</span></p>
        <ul style="list-style:none;padding:0;font-size:var(--text-sm);color:var(--text-muted);margin-bottom:var(--space-3)">
          <li style="padding:6px 0">✅ Unlimited uses</li>
          <li style="padding:6px 0">✅ 50,000 chars per request</li>
          <li style="padding:6px 0">✅ Priority support</li>
          <li style="padding:6px 0">✅ Advanced tone settings</li>
        </ul>
        <a href="#" class="btn-primary">Coming Soon</a>
      </div>
    </div>
  </main>
</Layout>
