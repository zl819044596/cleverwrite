---
import Layout from '../layouts/Layout.astro';
import pages from '../data/programmatic-pages.json';

// Get unique verbs and their counts
const verbData = {};
pages.forEach(p => {
  if (!verbData[p.verb]) verbData[p.verb] = { count: 0, displayVerb: p.displayVerb };
  verbData[p.verb].count++;
});

// Get unique content types and their counts
const typeData = {};
pages.forEach(p => {
  if (!typeData[p.contentType]) typeData[p.contentType] = { count: 0 };
  typeData[p.contentType].count++;
});

const verbs = Object.entries(verbData);
const types = Object.entries(typeData);
---

<Layout title="All Writing Tools — CleverWrite Free AI Toolkit" description="Browse all 458+ AI writing tools. Humanizer, Rewriter, Paraphraser, Summarizer, and more — all free." canonical="/tools">
  <main class="container">
    <h1 class="section-title mt-2">All Writing Tools</h1>
    <p class="section-subtitle mt-2">458+ free AI writing tools across 10 categories. Pick what you need.</p>

    <!-- Core Tools (Standalone) -->
    <section class="section-block">
      <h2 class="section-title">Core Tools</h2>
      <div class="grid-4">
        <a href="/humanizer/" class="tool-link-card">🤖 AI Humanizer</a>
        <a href="/ai-detector/" class="tool-link-card">🔍 AI Detector</a>
        <a href="/grammar-checker/" class="tool-link-card">✨ Grammar Checker</a>
        <a href="/paraphraser/" class="tool-link-card">🔄 Paraphraser</a>
        <a href="/summarizer/" class="tool-link-card">📝 Summarizer</a>
        <a href="/improver/" class="tool-link-card">⬆️ Text Improver</a>
        <a href="/expander/" class="tool-link-card">🔍 Text Expander</a>
        <a href="/shortener/" class="tool-link-card">✂️ Text Shortener</a>
      </div>
    </section>

    <!-- By Verb -->
    <section class="section-block">
      <h2 class="section-title">By Action</h2>
      <div class="grid-4">
        {verbs.sort().map(([v, d]) => (
          <div class="card">
            <div class="flex items-center justify-between">
              <div class="font-semibold text-sm">{d.displayVerb}</div>
              <div class="text-xs text-gray-400">{d.count} pages</div>
            </div>
            <div class="max-h-24 overflow-y-auto mt-2">
              {pages.filter(p => p.verb === v).slice(0, 5).map(p => (
                <a href={`/${p.slug}`} class="block text-xs text-blue-600 hover:underline truncate">
                  {p.contentType}
                </a>
              ))}
            </div>
            <a href={`/tools/?verb=${v}`} class="block text-xs text-blue-600 hover:underline mt-2">View all →</a>
          </div>
        ))}
      </div>
    </section>

    <!-- By Content Type -->
    <section class="section-block">
      <h2 class="section-title">By Content Type</h2>
      <div class="grid-4">
        {types.sort().slice(0, 20).map(([t, d]) => (
          <div class="card">
            <div class="font-semibold text-sm">{t}</div>
            <div class="text-xs text-gray-400">{d} tools</div>
          </div>
        ))}
      </div>
    </section>
  </main>
</Layout>
