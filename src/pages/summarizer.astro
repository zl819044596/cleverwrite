---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Free Summarizer — Condense Any Text | CleverWrite" description="Summarize any text to its key points. Save time reading long articles, papers, and documents." canonical="/summarizer">
  <main class="container section-block" style="padding-top:var(--space-3)">
    <section class="hero" style="padding:var(--space-3) 0">
      <h1>Free Summarizer</h1>
      <p>Condense any text to its key points. Save time reading long articles, research papers, and documents.</p>
    </section>

    <!-- Tool -->
    <div class="tool-panel">
      <textarea id="inputText" class="text-input" style="min-height:220px" placeholder="Paste long text to summarize..."></textarea>
      <div class="flex justify-between items-center mt-2">
        <span style="font-size:var(--text-xs);color:var(--text-muted)" id="charCount">0 / 5000</span>
        <button id="actionBtn" class="btn-primary">📝 Summarize Text</button>
      </div>
      <div id="resultArea" class="mt-3 hidden">
        <h3 style="font-size:var(--text-sm);font-weight:600;margin-bottom:var(--space-1)">Summary</h3>
        <div id="resultText" class="result-box"></div>
        <div class="flex gap-1 mt-2 items-center">
          <button id="copyBtn" class="btn-secondary">📋 Copy</button>
          <span id="statusBadge" style="font-size:var(--text-xs);color:var(--text-success)" class="hidden">✅ Done</span>
        </div>
      </div>
    </div>

    <!-- Related -->
    <section class="section-block">
      <h3 style="margin-bottom:var(--space-2)">Related Tools</h3>
      <div class="grid-3">
        <a href="/paraphraser/" class="tool-link-card">🔄 Paraphraser</a>
        <a href="/shorten-article/" class="tool-link-card">✂️ Shorten Article</a>
        <a href="/expand-essay/" class="tool-link-card">🔍 Expand Essay</a>
        <a href="/summarize-research-paper/" class="tool-link-card">📝 Summarize Research Paper</a>
        <a href="/humanizer/" class="tool-link-card">🤖 AI Humanizer</a>
      </div>
    </section>
  </main>
</Layout>

<script>
  const btn = document.getElementById('actionBtn');
  const textarea = document.getElementById('inputText');
  const resultArea = document.getElementById('resultArea');
  const resultText = document.getElementById('resultText');
  const copyBtn = document.getElementById('copyBtn');
  const statusBadge = document.getElementById('statusBadge');
  const charCount = document.getElementById('charCount');
  let isLoading = false;
  btn?.addEventListener('click', async () => {
    const text = textarea?.value.trim();
    if (!text || isLoading) return;
    isLoading = true;
    btn.disabled = true;
    btn.textContent = '⏳ Summarizing...';
    resultArea?.classList.add('hidden');
    statusBadge?.classList.add('hidden');
    try {
      const res = await fetch('/api/tool', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ text, verb: 'summarize' }) });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'API error');
      resultText.textContent = data.result;
      resultArea?.classList.remove('hidden');
      statusBadge.textContent = '✅ Done';
      statusBadge.className = '';
      statusBadge.style.cssText = 'font-size:var(--text-xs);color:var(--text-success)';
      statusBadge?.classList.remove('hidden');
    } catch (err) {
      resultText.textContent = 'Error: ' + err.message + '\n\nPlease try again.';
      resultArea?.classList.remove('hidden');
      statusBadge.textContent = '⚠️ Error';
      statusBadge.style.cssText = 'font-size:var(--text-xs);color:var(--text-error)';
      statusBadge?.classList.remove('hidden');
    } finally {
      isLoading = false; btn.disabled = false; btn.textContent = '📝 Summarize Text';
    }
  });
  copyBtn?.addEventListener('click', async () => {
    const text = resultText?.textContent;
    if (text) {
      try { await navigator.clipboard.writeText(text); copyBtn.textContent = '✅ Copied!'; setTimeout(() => { copyBtn.textContent = '📋 Copy'; }, 2000); }
      catch { const ta = document.createElement('textarea'); ta.value = text; document.body.appendChild(ta); ta.select(); document.execCommand('copy'); document.body.removeChild(ta); copyBtn.textContent = '✅ Copied!'; setTimeout(() => { copyBtn.textContent = '📋 Copy'; }, 2000); }
    }
  });
  textarea?.addEventListener('input', function() { charCount.textContent = this.value.length + ' / 5000'; });
</script>
