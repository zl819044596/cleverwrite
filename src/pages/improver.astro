---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Free Text Improver — Enhance Clarity & Readability | CleverWrite" description="Improve any text: fix errors, enhance clarity, boost readability, and polish your writing for free." canonical="/improver">
  <main class="container-narrow">
    <section class="hero">
      <h1>Free Text Improver</h1>
      <p>Fix errors, enhance clarity, improve flow, and boost readability. Make your writing clearer and more effective.</p>
    </section>

    <section class="tool-panel">
      <textarea id="inputText" class="text-input" placeholder="Paste text to improve..."></textarea>
      <div class="flex justify-between items-center mt-4">
        <span class="char-count" style="font-size: var(--text-sm); color: var(--text-muted);">0 / 5000 characters</span>
        <button id="actionBtn" class="btn-primary">⬆️ Improve Text</button>
      </div>
      <div id="resultArea" class="mt-6 hidden">
        <h3 class="mb-2">Improved Text</h3>
        <div id="resultText" class="result-box"></div>
        <div class="flex gap-2 mt-3">
          <button id="copyBtn" class="btn-secondary">📋 Copy</button>
          <span id="statusBadge" class="stat-badge success">✅ Done</span>
        </div>
      </div>
    </section>

    <section class="section-block">
      <h2>Related Tools</h2>
      <div class="grid-3">
        <a href="/grammar-checker" class="tool-link-card">✨ Grammar Checker</a>
        <a href="/polish-text" class="tool-link-card">✨ Polish Text</a>
        <a href="/paraphraser" class="tool-link-card">🔄 Paraphraser</a>
        <a href="/improve-essay" class="tool-link-card">⬆️ Improve Essay</a>
        <a href="/improve-email" class="tool-link-card">⬆️ Improve Email</a>
      </div>
    </section>
  </main>
</Layout>

<script>
  const btn = document.getElementById('actionBtn');
  const textarea = document.getElementById('inputText');
  const resultArea = document.getElementById('resultArea');
  const resultText = document.getElementById('resultText');
  const copyBtn = document.getElementById('copyBtn');
  const statusBadge = document.getElementById('statusBadge');
  const charCount = document.querySelector('.char-count');
  let isLoading = false;
  btn?.addEventListener('click', async () => {
    const text = textarea?.value.trim();
    if (!text || isLoading) return;
    isLoading = true;
    btn.disabled = true;
    btn.textContent = '⏳ Improving...';
    resultArea?.classList.add('hidden');
    try {
      const res = await fetch('/api/tool', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ text, verb: 'improve' }) });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'API error');
      resultText.textContent = data.result;
      resultArea?.classList.remove('hidden');
      statusBadge.textContent = '✅ Done';
    } catch (err) {
      resultText.textContent = 'Error: ' + err.message + '\n\nPlease try again.';
      resultArea?.classList.remove('hidden');
      statusBadge.textContent = '⚠️ Error';
      statusBadge.className = 'stat-badge error';
    } finally {
      isLoading = false; btn.disabled = false; btn.textContent = '⬆️ Improve Text';
    }
  });
  copyBtn?.addEventListener('click', async () => {
    const text = resultText?.textContent;
    if (text) {
      try { await navigator.clipboard.writeText(text); copyBtn.textContent = '✅ Copied!'; setTimeout(() => { copyBtn.textContent = '📋 Copy'; }, 2000); }
      catch { const ta = document.createElement('textarea'); ta.value = text; document.body.appendChild(ta); ta.select(); document.execCommand('copy'); document.body.removeChild(ta); copyBtn.textContent = '✅ Copied!'; setTimeout(() => { copyBtn.textContent = '📋 Copy'; }, 2000); }
    }
  });
  textarea?.addEventListener('input', function() { charCount.textContent = this.value.length + ' / 5000 characters'; });
</script>
