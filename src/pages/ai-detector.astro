---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Free AI Detector — Check If Text Is AI-Generated | CleverWrite" description="Check if text was written by AI. Detects GPTZero, ChatGPT, Claude & more. Free AI detection tool." canonical="/ai-detector/">
  <main class="container" style="padding-top:var(--space-4);padding-bottom:var(--space-5)">
    <section style="margin-bottom:var(--space-2)">
      <h1 style="font-size:1.75rem;font-weight:700;color:var(--text-title);margin-bottom:4px">Free AI Detector</h1>
      <p style="color:var(--text-muted);font-size:var(--text-sm)">Check if text was written by AI. Detects GPT3, ChatGPT, Claude, and more.</p>
    </section>

    <section class="tool-panel">
      <textarea
        id="inputText"
        class="text-input"
        style="min-height:220px;width:100%"
        placeholder="Paste text here to detect AI..."
      ></textarea>

      <div style="display:flex;justify-content:flex-end;align-items:center;gap:var(--space-2);margin-top:var(--space-2)">
        <span style="font-size:var(--text-sm);color:var(--text-muted)" id="charCount">0 / 10000 characters</span>
        <button id="detectBtn" class="btn-primary" style="padding:var(--space-1) var(--space-2)">
          Detect AI
        </button>
      </div>

      <div id="resultArea" style="display:none;margin-top:var(--space-3)">
        <div style="display:flex;align-items:center;gap:var(--space-3);margin-bottom:var(--space-2)">
          <div style="font-size:2.5rem;font-weight:700;color:var(--color-primary)" id="scoreDisplay">--</div>
          <div>
            <div style="font-size:var(--text-base);font-weight:600;color:var(--text-title)" id="labelDisplay">--</div>
            <div style="font-size:var(--text-xs);color:var(--text-muted)">AI probability score</div>
          </div>
        </div>

        <div style="width:100%;height:12px;background:var(--border-base);border-radius:6px;margin-bottom:var(--space-2);overflow:hidden">
          <div id="scoreBar" style="height:100%;border-radius:6px;width:0%;transition:width 0.5s ease"></div>
        </div>

        <div style="margin-bottom:var(--space-2)">
          <h3 style="font-size:var(--text-sm);font-weight:600;margin-bottom:6px;color:var(--text-title)">Analysis</h3>
          <ul id="reasonsList" style="font-size:var(--text-sm);color:var(--text-muted);padding-left:var(--space-2)"></ul>
        </div>

        <div>
          <h3 style="font-size:var(--text-sm);font-weight:600;margin-bottom:6px;color:var(--text-title)">Suspicious Phrases</h3>
          <div id="highlightsList" style="font-size:var(--text-sm);color:var(--text-muted)"></div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  const detectBtn = document.getElementById('detectBtn');
  const textarea = document.getElementById('inputText');
  const resultArea = document.getElementById('resultArea');
  const scoreDisplay = document.getElementById('scoreDisplay');
  const labelDisplay = document.getElementById('labelDisplay');
  const scoreBar = document.getElementById('scoreBar');
  const reasonsList = document.getElementById('reasonsList');
  const highlightsList = document.getElementById('highlightsList');
  const charCount = document.getElementById('charCount');
  let isLoading = false;

  function getScoreColor(score) {
    if (score >= 80) return '#EF4444';
    if (score >= 60) return '#F97316';
    if (score >= 40) return '#EAB308';
    if (score >= 20) return '#84CC16';
    return '#10B981';
  }

  function getScoreTextColor(score) {
    if (score >= 80) return '#DC2626';
    if (score >= 60) return '#EA580C';
    if (score >= 40) return '#CA8A04';
    return '#16A34A';
  }

  detectBtn?.addEventListener('click', async () => {
    const text = textarea?.value.trim();
    if (!text || isLoading) return;

    isLoading = true;
    detectBtn.disabled = true;
    detectBtn.textContent = '⏳ Analyzing...';
    resultArea.style.display = 'none';

    try {
      const res = await fetch('/api/detect', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text })
      });

      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'API error');

      const score = data.score || 0;
      scoreDisplay.textContent = score + '%';
      scoreDisplay.style.color = getScoreTextColor(score);
      labelDisplay.textContent = data.label || 'Uncertain';
      scoreBar.style.width = score + '%';
      scoreBar.style.background = getScoreColor(score);

      reasonsList.innerHTML = '';
      (data.reasons || ['Analysis complete']).forEach(r => {
        const li = document.createElement('li');
        li.textContent = r;
        reasonsList.appendChild(li);
      });

      highlightsList.innerHTML = '';
      if (data.highlights && data.highlights.length > 0) {
        data.highlights.forEach(h => {
          const span = document.createElement('span');
          span.style.cssText = 'display:inline-block;background:rgba(239,68,68,0.1);color:#DC2626;padding:2px 8px;border-radius:4px;margin-right:6px;margin-bottom:6px;font-size:var(--text-xs)';
          span.textContent = '"' + h + '"';
          highlightsList.appendChild(span);
        });
      } else {
        highlightsList.textContent = 'No suspicious patterns detected.';
      }

      resultArea.style.display = 'block';
    } catch (err) {
      scoreDisplay.textContent = '⚠️';
      labelDisplay.textContent = 'Error: ' + err.message;
      resultArea.style.display = 'block';
    } finally {
      isLoading = false;
      detectBtn.disabled = false;
      detectBtn.textContent = 'Detect AI';
    }
  });

  textarea?.addEventListener('input', function() {
    charCount.textContent = this.value.length + ' / 10000 characters';
  });
</script>
