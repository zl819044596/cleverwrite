---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Free Grammar Checker — Fix Grammar, Spelling & Style | CleverWrite" description="Check grammar, spelling, and punctuation for free. Get instant corrections and readability scores." canonical="/grammar-checker">
  <main class="max-w-3xl mx-auto px-4 py-12">
    <section class="text-center mb-8">
      <h1 class="text-4xl font-bold mb-2">Free Grammar Checker</h1>
      <p class="text-gray-600">Check grammar, spelling, punctuation, and style. Get instant corrections and readability scores.</p>
    </section>

    <section class="bg-white rounded-xl shadow-lg p-6 mb-8">
      <textarea
        id="inputText"
        class="w-full h-48 border border-gray-300 rounded-lg p-4 text-base focus:outline-none focus:ring-2 focus:ring-emerald-500 resize-none"
        placeholder="Paste your text here to check grammar..."
      ></textarea>

      <div class="flex justify-between items-center mt-4">
        <span class="text-sm text-gray-400" id="charCount">0 / 10000 characters</span>
        <button id="checkBtn" class="bg-emerald-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-emerald-700 transition disabled:opacity-50">
          ✨ Check Grammar
        </button>
      </div>

      <!-- Results Overview -->
      <div id="resultArea" class="mt-6 hidden">
        <div class="flex items-center gap-4 mb-6 p-4 bg-gray-50 rounded-lg">
          <div>
            <div class="text-3xl font-bold" id="errorCount">0</div>
            <div class="text-sm text-gray-500">errors found</div>
          </div>
          <div class="border-l pl-4">
            <div class="text-lg font-semibold">Readability</div>
            <div class="flex items-center gap-2">
              <span class="text-2xl font-bold" id="readabilityScore">--</span>
              <div class="w-24 bg-gray-200 rounded-full h-2.5">
                <div id="readabilityBar" class="h-2.5 rounded-full" style="width:0%"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Issues List -->
        <div id="issuesArea" class="mb-6">
          <h3 class="font-semibold mb-3">Issues Found</h3>
          <div id="issuesList" class="space-y-3"></div>
        </div>

        <!-- Corrected Text -->
        <div class="mb-6">
          <h3 class="font-semibold mb-2">Corrected Version</h3>
          <div id="correctedText" class="bg-gray-50 border rounded-lg p-4 min-h-[80px] whitespace-pre-wrap text-sm"></div>
          <button id="copyCorrectedBtn" class="mt-2 bg-gray-200 px-4 py-2 rounded-lg text-sm hover:bg-gray-300 transition">📋 Copy Corrected</button>
        </div>

        <!-- Suggestions -->
        <div id="suggestionsArea" class="p-4 bg-blue-50 rounded-lg">
          <h3 class="font-semibold mb-1 text-blue-800">💡 Suggestions</h3>
          <p id="suggestionsText" class="text-sm text-blue-700"></p>
        </div>
      </div>
    </section>

    <!-- Related Tools -->
    <section class="border-t pt-8">
      <h2 class="text-xl font-semibold mb-4">Related Tools</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
        <a href="/humanizer" class="block p-3 border rounded-lg hover:bg-gray-50 transition">🤖 AI Humanizer</a>
        <a href="/polish-email" class="block p-3 border rounded-lg hover:bg-gray-50 transition">📧 Polish Email</a>
        <a href="/improve-essay" class="block p-3 border rounded-lg hover:bg-gray-50 transition">📄 Improve Essay</a>
        <a href="/simplify-text" class="block p-3 border rounded-lg hover:bg-gray-50 transition">📖 Simplify Text</a>
        <a href="/paraphraser" class="block p-3 border rounded-lg hover:bg-gray-50 transition">🔄 Paraphraser</a>
        <a href="/ai-detector" class="block p-3 border rounded-lg hover:bg-gray-50 transition">🔍 AI Detector</a>
      </div>
    </section>
  </main>
</Layout>

<script>
  const checkBtn = document.getElementById('checkBtn');
  const textarea = document.getElementById('inputText');
  const resultArea = document.getElementById('resultArea');
  const errorCount = document.getElementById('errorCount');
  const readabilityScore = document.getElementById('readabilityScore');
  const readabilityBar = document.getElementById('readabilityBar');
  const issuesList = document.getElementById('issuesList');
  const correctedText = document.getElementById('correctedText');
  const copyCorrectedBtn = document.getElementById('copyCorrectedBtn');
  const suggestionsText = document.getElementById('suggestionsText');
  const charCount = document.getElementById('charCount');
  let isLoading = false;

  function getScoreColor(score) {
    if (score >= 80) return 'bg-green-500';
    if (score >= 60) return 'bg-lime-500';
    if (score >= 40) return 'bg-yellow-500';
    return 'bg-red-500';
  }

  checkBtn?.addEventListener('click', async () => {
    const text = textarea?.value.trim();
    if (!text || isLoading) return;

    isLoading = true;
    checkBtn.disabled = true;
    checkBtn.textContent = '⏳ Analyzing...';
    resultArea?.classList.add('hidden');

    try {
      const res = await fetch('/api/grammar', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text })
      });

      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'API error');

      // Overview
      errorCount.textContent = data.errorCount || 0;
      const rs = data.readabilityScore || 0;
      readabilityScore.textContent = rs + '/100';
      readabilityBar.style.width = rs + '%';
      readabilityBar.className = 'h-2.5 rounded-full ' + getScoreColor(rs);

      // Issues
      issuesList.innerHTML = '';
      if (data.issues && data.issues.length > 0) {
        data.issues.forEach(issue => {
          const div = document.createElement('div');
          div.className = 'p-3 border-l-4 border-yellow-400 bg-yellow-50 rounded-r-lg';
          div.innerHTML = `
            <div class="flex items-start gap-2">
              <span class="text-xs font-medium uppercase text-yellow-700 bg-yellow-100 px-2 py-0.5 rounded">${issue.type || 'error'}</span>
            </div>
            <div class="mt-1">
              <span class="line-through text-red-600">${issue.original || ''}</span>
              <span class="text-green-600 font-medium ml-2">→ ${issue.suggestion || ''}</span>
            </div>
            <div class="text-xs text-gray-500 mt-1">${issue.explanation || ''}</div>
          `;
          issuesList.appendChild(div);
        });
      } else {
        issuesList.innerHTML = '<div class="text-green-600 font-medium">✅ No issues found! Your text looks good.</div>';
      }

      // Corrected text
      correctedText.textContent = data.correctedText || text;

      // Suggestions
      suggestionsText.textContent = data.suggestions || 'Review complete.';

      resultArea?.classList.remove('hidden');
    } catch (err) {
      errorCount.textContent = '⚠️';
      suggestionsText.textContent = 'Error: ' + err.message;
      resultArea?.classList.remove('hidden');
    } finally {
      isLoading = false;
      checkBtn.disabled = false;
      checkBtn.textContent = '✨ Check Grammar';
    }
  });

  copyCorrectedBtn?.addEventListener('click', async () => {
    const text = correctedText?.textContent;
    if (text) {
      try {
        await navigator.clipboard.writeText(text);
        copyCorrectedBtn.textContent = '✅ Copied!';
        setTimeout(() => { copyCorrectedBtn.textContent = '📋 Copy Corrected'; }, 2000);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = text;
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        copyCorrectedBtn.textContent = '✅ Copied!';
        setTimeout(() => { copyCorrectedBtn.textContent = '📋 Copy Corrected'; }, 2000);
      }
    }
  });

  textarea?.addEventListener('input', function() {
    charCount.textContent = this.value.length + ' / 10000 characters';
  });
</script>
