---
import Layout from '../layouts/Layout.astro';
import pages from '../data/programmatic-pages.json';

// Get unique verbs
const verbMap = {};
pages.forEach(p => {
  if (!verbMap[p.verb]) verbMap[p.verb] = { verb: p.verb, displayVerb: p.displayVerb, count: 0 };
  verbMap[p.verb].count++;
});
const verbs = Object.values(verbMap).sort((a, b) => b.count - a.count);

// Content type groups
const typeGroups = [
  { name: 'Essay', icon: '📄', slug: 'humanize-essay', count: 10 },
  { name: 'Email', icon: '✉️', slug: 'rewrite-email', count: 9 },
  { name: 'Blog Post', icon: '📝', slug: 'improve-blog-post', count: 8 },
  { name: 'Research', icon: '🔬', slug: 'summarize-research-paper', count: 8 },
  { name: 'Cover Letter', icon: '📋', slug: 'paraphrase-cover-letter', count: 8 },
  { name: 'LinkedIn', icon: '💼', slug: 'polish-linkedin-post', count: 8 },
  { name: 'Story', icon: '📖', slug: 'expand-story', count: 6 },
  { name: 'Homework', icon: '🎒', slug: 'simplify-homework', count: 9 },
];

const popularPages = [
  { slug: 'humanize-chatgpt', label: 'Humanize ChatGPT' },
  { slug: 'humanize-essay', label: 'Humanize Essay' },
  { slug: 'rewrite-resume', label: 'Rewrite Resume' },
  { slug: 'paraphrase-essay', label: 'Paraphrase Essay' },
  { slug: 'summarize-article', label: 'Summarize Article' },
  { slug: 'improve-email', label: 'Improve Email' },
  { slug: 'expand-blog-post', label: 'Expand Blog Post' },
  { slug: 'shorten-essay', label: 'Shorten Essay' },
  { slug: 'polish-email', label: 'Polish Email' },
  { slug: 'formalize-email', label: 'Formalize Email' },
  { slug: 'simplify-essay', label: 'Simplify Essay' },
  { slug: 'humanize-resume', label: 'Humanize Resume' },
  { slug: 'rewrite-cover-letter', label: 'Rewrite Cover Letter' },
  { slug: 'paraphrase-research-paper', label: 'Paraphrase Paper' },
  { slug: 'summarize-youtube-script', label: 'Summarize Script' },
  { slug: 'humanize-linkedin-post', label: 'Humanize LinkedIn' },
];
---

<Layout title="CleverWrite — Free AI Writing Toolkit" description="The most complete free AI writing toolkit — 460+ pages & 10 writing tools. Humanizer, Grammar Checker, Paraphraser & more." canonical="/">
  <!-- Hero with dual panel -->
  <section class="hero">
    <h1>Free AI Writing Toolkit</h1>
    <p>Humanizer, Grammar Checker, Paraphraser, Summarizer & more — all free, no signup.</p>
    <div class="hero-actions">
      <a href="/humanizer" class="btn-primary">🤖 Try AI Humanizer</a>
      <a href="/grammar-checker" class="btn-secondary">✨ Check Grammar</a>
    </div>
  </section>

  <main class="container section-block">
    <!-- Core Tools -->
    <section class="section-block">
      <h2 class="section-title">Core Tools</h2>
      <p class="section-subtitle">Professional AI writing tools, free for everyone.</p>
      <div class="grid-3">
        <a href="/humanizer" class="card"><h3>🤖 AI Humanizer</h3><p style="font-size:var(--text-sm);color:var(--text-muted);margin-top:4px">Make AI text sound human</p></a>
        <a href="/ai-detector" class="card"><h3>🔍 AI Detector</h3><p style="font-size:var(--text-sm);color:var(--text-muted);margin-top:4px">Detect AI-written content</p></a>
        <a href="/grammar-checker" class="card"><h3>✨ Grammar Checker</h3><p style="font-size:var(--text-sm);color:var(--text-muted);margin-top:4px">Fix grammar & style</p></a>
        <a href="/paraphraser" class="card"><h3>🔄 Paraphraser</h3><p style="font-size:var(--text-sm);color:var(--text-muted);margin-top:4px">Rewrite any text in new words</p></a>
        <a href="/summarizer" class="card"><h3>📝 Summarizer</h3><p style="font-size:var(--text-sm);color:var(--text-muted);margin-top:4px">Condense long content</p></a>
        <a href="/improver" class="card"><h3>⬆️ Text Improver</h3><p style="font-size:var(--text-sm);color:var(--text-muted);margin-top:4px">Enhance clarity & flow</p></a>
        <a href="/expander" class="card"><h3>🔍 Text Expander</h3><p style="font-size:var(--text-sm);color:var(--text-muted);margin-top:4px">Add depth & detail</p></a>
        <a href="/shortener" class="card"><h3>✂️ Text Shortener</h3><p style="font-size:var(--text-sm);color:var(--text-muted);margin-top:4px">Make text concise</p></a>
        <a href="/polish-email" class="card"><h3>✨ Polish Email</h3><p style="font-size:var(--text-sm);color:var(--text-muted);margin-top:4px">Polish email writing</p></a>
        <a href="/simplify-text" class="card"><h3>📖 Simplify Text</h3><p style="font-size:var(--text-sm);color:var(--text-muted);margin-top:4px">Plain language, easy reading</p></a>
        <a href="/formalize-text" class="card"><h3>👔 Formalize Text</h3><p style="font-size:var(--text-sm);color:var(--text-muted);margin-top:4px">Professional tone</p></a>
        <a href="/tools" class="card" style="display:flex;align-items:center;justify-content:center;border:1px dashed var(--border-base)">
          <span style="color:var(--color-primary);font-weight:500">View All 458 Pages →</span>
        </a>
      </div>
    </section>

    <!-- By Content Type -->
    <section class="section-block">
      <h2 class="section-title">By Content Type</h2>
      <p class="section-subtitle">Pick what you're writing, we have the right tool.</p>
      <div class="grid-4">
        {typeGroups.map(t => (
          <a href={`/${t.slug}`} class="type-card">
            <div class="icon">{t.icon}</div>
            <div class="name">{t.name}</div>
            <div class="count">{t.count} tools</div>
          </a>
        ))}
      </div>
    </section>

    <!-- By Action -->
    <section class="section-block">
      <h2 class="section-title">By Action</h2>
      <p class="section-subtitle">Choose what you want to do with your text.</p>
      <div class="grid-2" style="grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:var(--space-2)">
        {verbs.map(v => (
          <a href={`/tools?verb=${v.verb}`} class="tool-link-card" style="text-align:center">
            <div style="font-weight:600;font-size:var(--text-sm)">{v.displayVerb}</div>
            <div style="font-size:var(--text-xs);color:var(--text-muted)">{v.count} pages</div>
          </a>
        ))}
      </div>
    </section>

    <!-- Popular Pages -->
    <section class="section-block">
      <h2 class="section-title">Popular Pages</h2>
      <div class="grid-4">
        {popularPages.map(p => (
          <a href={`/${p.slug}`} class="tool-link-card">{p.label}</a>
        ))}
      </div>
      <div class="text-center mt-3">
        <a href="/tools" class="btn-secondary">Browse all 458 pages →</a>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section-block">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="card" style="padding:var(--space-3)">
        <div class="faq-item">
          <div class="faq-q">Is CleverWrite really free?</div>
          <div class="faq-a">Yes. All core tools are free with no registration required. Use up to 5,000 characters per request.</div>
        </div>
        <div class="faq-item">
          <div class="faq-q">How does the AI Humanizer work?</div>
          <div class="faq-a">AI Humanizer rewrites AI-generated text to sound naturally human-written. It removes AI patterns, varies sentence structure, and adds natural language.</div>
        </div>
        <div class="faq-item">
          <div class="faq-q">Do you store my text?</div>
          <div class="faq-a">No. Your text is processed in real-time and never stored on our servers.</div>
        </div>
        <div class="faq-item">
          <div class="faq-q">Which content types do you support?</div>
          <div class="faq-a">Over 50 content types across academic, professional, email, social media, content marketing, creative, and web writing.</div>
        </div>
      </div>
    </section>
  </main>
</Layout>
