---
import Layout from '../layouts/Layout.astro';
---

<Layout title="CleverWrite — Free AI Humanizer & Writing Tools" description="Free AI Humanizer for essays, scripts & content. Rewrite AI text into natural writing while keeping your original meaning." canonical="/">
  <!-- Dual-panel Hero -->
  <section class="hero-dual">
    <div class="hero-dual-inner">
      <h1 class="hero-dual-title">Free AI Humanizer<br>for Essays, Scripts &amp; Content</h1>
      <p class="hero-dual-sub">Rewrite AI text into natural writing while keeping your original meaning</p>

      <div class="dual-panel">
        <div class="panel panel-input">
          <div class="panel-label">
            <span class="panel-dot"></span>
            Original AI Text
          </div>
          <textarea id="heroInput" class="panel-textarea" placeholder="Paste your AI-generated text here...">The integration of artificial intelligence into modern educational frameworks has fundamentally transformed the pedagogical landscape, enabling unprecedented levels of personalized learning experiences for students across diverse academic disciplines.</textarea>
        </div>

        <div class="panel-divider">
          <button id="heroHumanizeBtn" class="panel-arrow-btn" title="Humanize">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
        </div>

        <div class="panel panel-output">
          <div class="panel-label">
            <span class="panel-dot panel-dot-green"></span>
            Humanized Writing
          </div>
          <div id="heroOutput" class="panel-textarea panel-output-text" style="color:var(--text-muted)">
            <span style="opacity:0.5">Click the arrow to humanize...</span>
          </div>
        </div>
      </div>

      <!-- Feature badges -->
      <div class="hero-badges">
        <a href="/humanizer/" class="badge-link active">🤖 Humanize Text</a>
        <a href="/ai-detector/" class="badge-link">🔍 AI Detector</a>
        <a href="/grammar-checker/" class="badge-link">✨ Check Grammar</a>
        <a href="/paraphraser/" class="badge-link">🔄 Paraphraser</a>
        <a href="/summarizer/" class="badge-link">📝 Summarizer</a>
        <a href="/translator/" class="badge-link">🌐 Translator</a>
        <a href="/smart-rewriter/" class="badge-link">🧠 Smart Rewriter</a>
      </div>
    </div>
  </section>

  <!-- Trust Strip -->
  <section class="trust-strip">
    <span class="trust-item"><span class="icon">🔒</span> Encrypted processing</span>
    <span class="trust-item"><span class="icon">🚫</span> No storage</span>
    <span class="trust-item"><span class="icon">🆓</span> No signup required</span>
    <span class="trust-item"><span class="icon">♾️</span> Unlimited usage</span>
  </section>

  <!-- Minimal below-fold: just core tools -->
  <main class="container" style="padding-bottom:var(--space-5)">
    <section class="section-block">
      <div class="grid-4">
        <a href="/humanizer/" class="card"><h3>🤖 AI Humanizer</h3><p style="font-size:var(--text-sm);color:var(--text-muted);margin-top:4px">Make AI text sound human</p></a>
        <a href="/ai-detector/" class="card"><h3>🔍 AI Detector</h3><p style="font-size:var(--text-sm);color:var(--text-muted);margin-top:4px">Detect AI-written content</p></a>
        <a href="/grammar-checker/" class="card"><h3>✨ Grammar Checker</h3><p style="font-size:var(--text-sm);color:var(--text-muted);margin-top:4px">Fix grammar & style</p></a>
        <a href="/paraphraser/" class="card"><h3>🔄 Paraphraser</h3><p style="font-size:var(--text-sm);color:var(--text-muted);margin-top:4px">Rewrite any text</p></a>
        <a href="/summarizer/" class="card"><h3>📝 Summarizer</h3><p style="font-size:var(--text-sm);color:var(--text-muted);margin-top:4px">Condense long content</p></a>
        <a href="/improver/" class="card"><h3>⬆️ Text Improver</h3><p style="font-size:var(--text-sm);color:var(--text-muted);margin-top:4px">Enhance clarity & flow</p></a>
        <a href="/expander/" class="card"><h3>🔍 Text Expander</h3><p style="font-size:var(--text-sm);color:var(--text-muted);margin-top:4px">Add depth & detail</p></a>
        <a href="/tools/" class="card" style="display:flex;align-items:center;justify-content:center;border:1px dashed var(--border-base)">
          <span style="color:var(--color-primary);font-weight:500">+ 450 more pages →</span>
        </a>
      </div>
    </section>

    <!-- All Tools Grid -->
    <section class="section-block">
      <h2 class="section-title text-center">All Writing Tools</h2>
      <p class="section-subtitle text-center">Free AI-powered tools for every writing need</p>
      <div class="tools-grid">
        <a href="/humanizer/" class="tool-pill"><span class="emoji">🤖</span> AI Humanizer</a>
        <a href="/ai-detector/" class="tool-pill"><span class="emoji">🔍</span> AI Detector</a>
        <a href="/grammar-checker/" class="tool-pill"><span class="emoji">✨</span> Grammar Checker</a>
        <a href="/paraphraser/" class="tool-pill"><span class="emoji">🔄</span> Paraphraser</a>
        <a href="/summarizer/" class="tool-pill"><span class="emoji">📝</span> Summarizer</a>
        <a href="/translator/" class="tool-pill"><span class="emoji">🌐</span> Translator</a>
        <a href="/smart-rewriter/" class="tool-pill"><span class="emoji">🧠</span> Smart Rewriter</a>
        <a href="/improver/" class="tool-pill"><span class="emoji">⬆️</span> Text Improver</a>
        <a href="/expander/" class="tool-pill"><span class="emoji">🔍</span> Text Expander</a>
        <a href="/plagiarism-checker/" class="tool-pill"><span class="emoji">📋</span> Plagiarism Checker</a>
        <a href="/citation-generator/" class="tool-pill"><span class="emoji">📚</span> Citation Generator</a>
        <a href="/essay-writer/" class="tool-pill"><span class="emoji">✍️</span> Essay Writer</a>
      </div>
    </section>
  </main>

  <!-- Upgrade Modal -->
  <div id="upgradeModal" class="modal-overlay hidden">
    <div class="modal-card">
      <button class="modal-close-btn" id="upgradeModalClose" aria-label="Close">✕</button>
      <div class="modal-icon">⚡</div>
      <h3>Free Limit Reached</h3>
      <p>You've used your 3 free humanizations today. Upgrade to Pro for unlimited access, priority processing, and advanced features.</p>
      <div class="modal-actions">
        <a href="/pricing/" class="btn-primary">View Plans</a>
        <button id="upgradeModalLater" class="btn-secondary">Maybe Later</button>
      </div>
    </div>
  </div>
</Layout>

<style>
  /* Dual-panel hero */
  .hero-dual {
    background: var(--bg-page);
    border-bottom: 1px solid var(--border-light);
    padding: var(--space-3) var(--space-2) var(--space-4);
  }
  .hero-dual-inner {
    max-width: 1000px;
    margin: 0 auto;
  }
  .hero-dual-title {
    font-size: 28px;
    font-weight: 700;
    color: var(--text-title);
    line-height: 1.3;
    margin-bottom: 6px;
    text-align: center;
  }
  .hero-dual-sub {
    font-size: var(--text-sm);
    color: var(--text-muted);
    text-align: center;
    margin-bottom: var(--space-3);
  }

  /* Dual panel */
  .dual-panel {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0;
    align-items: stretch;
    margin-bottom: var(--space-3);
  }

  .panel {
    background: var(--bg-card);
    border: 1px solid var(--border-base);
    border-radius: var(--radius-md);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .panel-input {
    border-top-right-radius: 0;
    border-bottom-right-radius: 0;
    border-right: none;
  }
  .panel-output {
    border-top-left-radius: 0;
    border-bottom-left-radius: 0;
    border-left: none;
  }

  .panel-label {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--text-muted);
    padding: 8px 12px;
    border-bottom: 1px solid var(--border-light);
    display: flex;
    align-items: center;
    gap: 6px;
    background: var(--bg-page);
  }
  .panel-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-primary);
    display: inline-block;
  }
  .panel-dot-green {
    background: var(--success);
  }

  .panel-textarea {
    flex: 1;
    border: none;
    padding: var(--space-2);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    line-height: var(--leading-base);
    color: var(--text-body);
    background: var(--bg-card);
    resize: none;
    min-height: 200px;
    outline: none;
  }
  .panel-input .panel-textarea {
    background: var(--bg-input);
  }
  .panel-output-text {
    white-space: pre-wrap;
    overflow-y: auto;
  }
  .panel-output-text.loading {
    opacity: 0.5;
  }

  /* Divider with arrow */
  .panel-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-page);
    padding: 0 4px;
  }
  .panel-arrow-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--border-base);
    background: var(--bg-card);
    color: var(--color-primary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }
  .panel-arrow-btn:hover {
    background: var(--color-primary);
    color: #ffffff;
    border-color: var(--color-primary);
  }
  .panel-arrow-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  /* Badges */
  .hero-badges {
    display: flex;
    gap: 8px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .badge-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 6px 14px;
    border-radius: 20px;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-muted);
    background: var(--bg-card);
    border: 1px solid var(--border-base);
    transition: all 0.2s ease;
  }
  .badge-link:hover {
    color: var(--color-primary);
    border-color: var(--color-primary-fade);
    background: var(--color-primary-fade);
  }
  .badge-link.active {
    color: var(--color-primary);
    border-color: var(--color-primary);
    background: var(--color-primary-fade);
  }

  @media (max-width: 767px) {
    .dual-panel {
      grid-template-columns: 1fr;
    }
    .panel-input {
      border-radius: var(--radius-md);
      border-right: 1px solid var(--border-base);
      border-bottom: none;
    }
    .panel-output {
      border-radius: var(--radius-md);
      border-left: 1px solid var(--border-base);
      border-top: none;
    }
    .panel-divider {
      padding: 4px 0;
    }
    .panel-arrow-btn {
      transform: rotate(90deg);
    }
    .hero-dual-title {
      font-size: 22px;
    }
    .panel-textarea {
      min-height: 140px;
    }
  }
</style>

<script>
  const heroInput = document.getElementById('heroInput');
  const heroOutput = document.getElementById('heroOutput');
  const heroBtn = document.getElementById('heroHumanizeBtn');
  let isLoading = false;

  heroBtn?.addEventListener('click', async () => {
    const text = heroInput?.value.trim();
    if (!text || isLoading) return;

    isLoading = true;
    heroBtn.disabled = true;
    heroOutput.textContent = '⏳ Humanizing...';
    heroOutput.classList.add('loading');

    try {
      const res = await fetch('/api/humanize', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text, tone: 'casual' })
      });
      const data = await res.json();
      if (!res.ok) {
        // Check for rate limit / daily limit errors
        if (res.status === 429 || data.limit || (data.error && data.error.toLowerCase().includes('limit'))) {
          showUpgradeModal();
          heroOutput.textContent = '⚠️ Daily limit reached. Upgrade to Pro for unlimited access.';
          heroOutput.classList.remove('loading');
          return;
        }
        throw new Error(data.error || 'API error');
      }
      heroOutput.textContent = data.result;
      heroOutput.classList.remove('loading');
    } catch (err) {
      heroOutput.textContent = 'Error: ' + err.message;
      heroOutput.classList.remove('loading');
    } finally {
      isLoading = false;
      heroBtn.disabled = false;
    }
  });

  // Upgrade modal
  const upgradeModal = document.getElementById('upgradeModal');
  const upgradeClose = document.getElementById('upgradeModalClose');
  const upgradeLater = document.getElementById('upgradeModalLater');

  function showUpgradeModal() {
    upgradeModal?.classList.remove('hidden');
  }

  function hideUpgradeModal() {
    upgradeModal?.classList.add('hidden');
  }

  upgradeClose?.addEventListener('click', hideUpgradeModal);
  upgradeLater?.addEventListener('click', hideUpgradeModal);
  upgradeModal?.addEventListener('click', (e) => {
    if (e.target === upgradeModal) hideUpgradeModal();
  });

  // Expose modal trigger globally so other scripts can call it
  window.showUpgradeModal = showUpgradeModal;
</script>
