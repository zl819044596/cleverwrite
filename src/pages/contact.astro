---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — CleverWrite" description="Get in touch with the CleverWrite team." canonical="/contact/">
  <main class="container section-block" style="padding-top:var(--space-4);padding-bottom:var(--space-5);max-width:600px;text-align:center">
