---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Free Text Expander — Make Text Longer & More Detailed | CleverWrite" description="Expand your text with more detail, examples, and depth. Make short content more comprehensive for free." canonical="/expander">
  <main class="max-w-3xl mx-auto px-4 py-12">
    <section class="text-center mb-8">
      <h1>Free Text Expander</h1>
      <p style="color: #718096;">Expand your text with more detail, examples, and depth. Perfect for fleshing out outlines and short drafts.</p>
    </section>

    <section class="tool-panel">
      <textarea id="inputText" class="w-full h-48 border border-gray-300 rounded-lg p-4 text-base focus:outline-none focus:ring-2 focus:ring-sky-500 resize-none" placeholder="Paste short text to expand..."></textarea>
      <div class="flex justify-between items-center mt-4">
        <span class="text-sm text-gray-400 char-count">0 / 5000 characters</span>
        <button id="actionBtn" class="btn-primary hover:bg-sky-700 transition disabled:opacity-50">🔍 Expand Text</button>
      </div>
      <div id="resultArea" class="mt-6 hidden">
        <h3 class="font-semibold mb-2">Expanded Text</h3>
        <div id="resultText" class="bg-gray-50 border rounded-lg p-4 min-h-[100px] whitespace-pre-wrap"></div>
        <div class="flex gap-3 mt-3">
          <button id="copyBtn" class="bg-gray-200 px-4 py-2 rounded-lg hover:bg-gray-300 transition">📋 Copy</button>
          <span id="statusBadge" class="inline-flex items-center gap-1 text-green-600 text-sm">✅ Done</span>
        </div>
      </div>
    </section>

    <section class="border-t pt-8">
      <h2 class="text-xl font-semibold mb-4">Related Tools</h2>
      <div class="grid-3">
        <a href="/shortener/" class="tool-link-card">✂️ Text Shortener</a>
        <a href="/summarizer/" class="tool-link-card">📝 Summarizer</a>
        <a href="/expand-essay/" class="tool-link-card">🔍 Expand Essay</a>
        <a href="/expand-blog-post/" class="tool-link-card">🔍 Expand Blog Post</a>
        <a href="/paraphraser/" class="tool-link-card">🔄 Paraphraser</a>
      </div>
    </section>
  </main>
</Layout>

<script>
  const btn = document.getElementById('actionBtn');
  const textarea = document.getElementById('inputText');
  const resultArea = document.getElementById('resultArea');
  const resultText = document.getElementById('resultText');
  const copyBtn = document.getElementById('copyBtn');
  const statusBadge = document.getElementById('statusBadge');
  const charCount = document.querySelector('.char-count');
  let isLoading = false;
  btn?.addEventListener('click', async () => {
    const text = textarea?.value.trim();
    if (!text || isLoading) return;
    isLoading = true;
    btn.disabled = true;
    btn.textContent = '⏳ Expanding...';
    resultArea?.classList.add('hidden');
    try {
      const res = await fetch('/api/tool', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ text, verb: 'expand' }) });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'API error');
      resultText.textContent = data.result;
      resultArea?.classList.remove('hidden');
      statusBadge.textContent = '✅ Done';
    } catch (err) {
      resultText.textContent = 'Error: ' + err.message + '\n\nPlease try again.';
      resultArea?.classList.remove('hidden');
      statusBadge.textContent = '⚠️ Error';
      statusBadge.className = 'inline-flex items-center gap-1 text-red-600 text-sm';
    } finally {
      isLoading = false; btn.disabled = false; btn.textContent = '🔍 Expand Text';
    }
  });
  copyBtn?.addEventListener('click', async () => {
    const text = resultText?.textContent;
    if (text) {
      try { await navigator.clipboard.writeText(text); copyBtn.textContent = '✅ Copied!'; setTimeout(() => { copyBtn.textContent = '📋 Copy'; }, 2000); }
      catch { const ta = document.createElement('textarea'); ta.value = text; document.body.appendChild(ta); ta.select(); document.execCommand('copy'); document.body.removeChild(ta); copyBtn.textContent = '✅ Copied!'; setTimeout(() => { copyBtn.textContent = '📋 Copy'; }, 2000); }
    }
  });
  textarea?.addEventListener('input', function() { charCount.textContent = this.value.length + ' / 5000 characters'; });
</script>
