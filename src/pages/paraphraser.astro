---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Free Paraphraser — Rephrase Any Text | CleverWrite" description="Paraphrase any text for free. Reword sentences, avoid plagiarism, and improve clarity." canonical="/paraphraser">
  <main class="container section-block" style="padding-top:var(--space-3)">
    <nav class="breadcrumbs">
      <a href="/">Home</a>
      <span>/</span>
      <span>Paraphraser</span>
    </nav>

    <section class="hero" style="padding:var(--space-3) 0">
      <h1>Free Paraphraser</h1>
      <p>Rephrase any text to express the same ideas in new words. Perfect for avoiding plagiarism and improving clarity.</p>
    </section>

    <!-- Tool -->
    <div class="tool-panel">
      <textarea id="inputText" class="text-input" style="min-height:220px" placeholder="Paste text to paraphrase..."></textarea>
      <div class="flex justify-between items-center mt-2">
        <span style="font-size:var(--text-xs);color:var(--text-muted)" id="charCount">0 / 5000</span>
        <button id="actionBtn" class="btn-primary">🔄 Paraphrase Text</button>
      </div>
      <div id="resultArea" class="mt-3 hidden">
        <h3 style="font-size:var(--text-sm);font-weight:600;margin-bottom:var(--space-1)">Paraphrased Text</h3>
        <div id="resultText" class="result-box"></div>
        <div class="flex gap-1 mt-2 items-center">
          <button id="copyBtn" class="btn-secondary">📋 Copy</button>
          <span id="statusBadge" style="font-size:var(--text-xs);color:var(--text-success)" class="hidden">✅ Done</span>
        </div>
      </div>
    </div>

    <!-- How To -->
    <div class="card section-block">
      <h3 style="margin-bottom:var(--space-2)">How to Use</h3>
      <ol style="font-size:var(--text-sm);color:var(--text-muted);padding-left:var(--space-2)">
        <li style="margin-bottom:var(--space-1)">Paste the text you want to paraphrase into the input box</li>
        <li style="margin-bottom:var(--space-1)">Click "Paraphrase Text"</li>
        <li style="margin-bottom:var(--space-1)">Copy the paraphrased result and use it anywhere</li>
      </ol>
    </div>

    <!-- Use Cases -->
    <div class="card section-block">
      <h3 style="margin-bottom:var(--space-2)">Use Cases</h3>
      <ul style="font-size:var(--text-sm);color:var(--text-muted);padding-left:var(--space-2)">
        <li style="margin-bottom:var(--space-1)">Students — rephrase sources to avoid plagiarism while keeping the meaning</li>
        <li style="margin-bottom:var(--space-1)">Content writers — rewrite sentences for better clarity and flow</li>
        <li style="margin-bottom:var(--space-1)">Professionals — polish emails, reports, and business communications</li>
      </ul>
    </div>

    <!-- FAQ -->
    <div class="card section-block">
      <h3 style="margin-bottom:var(--space-2)">FAQ</h3>
      <div class="faq-item">
        <div class="faq-q">Is paraphrasing the same as rewriting?</div>
        <div class="faq-a">Paraphrasing means restating the same idea in different words. It's a form of rewriting that preserves the original meaning while changing the phrasing and sentence structure.</div>
      </div>
      <div class="faq-item">
        <div class="faq-q">Is it free?</div>
        <div class="faq-a">Yes, completely free. No signup needed. Up to 5,000 characters per request.</div>
      </div>
    </div>

    <!-- Related -->
    <section class="section-block">
      <h3 style="margin-bottom:var(--space-2)">Related Tools</h3>
      <div class="grid-3">
        <a href="/humanizer/" class="tool-link-card">🤖 AI Humanizer</a>
        <a href="/summarizer/" class="tool-link-card">📝 Summarizer</a>
        <a href="/grammar-checker/" class="tool-link-card">✨ Grammar Checker</a>
        <a href="/rewrite-essay/" class="tool-link-card">✏️ Rewrite Essay</a>
        <a href="/improve-article/" class="tool-link-card">⬆️ Improve Article</a>
      </div>
    </section>
  </main>
</Layout>

<script>
  const btn = document.getElementById('actionBtn');
  const textarea = document.getElementById('inputText');
  const resultArea = document.getElementById('resultArea');
  const resultText = document.getElementById('resultText');
  const copyBtn = document.getElementById('copyBtn');
  const statusBadge = document.getElementById('statusBadge');
  const charCount = document.getElementById('charCount');
  let isLoading = false;

  btn?.addEventListener('click', async () => {
    const text = textarea?.value.trim();
    if (!text || isLoading) return;
    isLoading = true;
    btn.disabled = true;
    btn.textContent = '⏳ Paraphrasing...';
    resultArea?.classList.add('hidden');
    statusBadge?.classList.add('hidden');
    try {
      const res = await fetch('/api/tool', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text, verb: 'paraphrase' })
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'API error');
      resultText.textContent = data.result;
      resultArea?.classList.remove('hidden');
      statusBadge.textContent = '✅ Done';
      statusBadge.className = '';
      statusBadge.style.cssText = 'font-size:var(--text-xs);color:var(--text-success)';
      statusBadge?.classList.remove('hidden');
    } catch (err) {
      resultText.textContent = 'Error: ' + err.message + '\n\nPlease try again.';
      resultArea?.classList.remove('hidden');
      statusBadge.textContent = '⚠️ Error';
      statusBadge.style.cssText = 'font-size:var(--text-xs);color:var(--text-error)';
      statusBadge?.classList.remove('hidden');
    } finally {
      isLoading = false;
      btn.disabled = false;
      btn.textContent = '🔄 Paraphrase Text';
    }
  });

  copyBtn?.addEventListener('click', async () => {
    const text = resultText?.textContent;
    if (text) {
      try { await navigator.clipboard.writeText(text); copyBtn.textContent = '✅ Copied!'; setTimeout(() => { copyBtn.textContent = '📋 Copy'; }, 2000); }
      catch { const ta = document.createElement('textarea'); ta.value = text; document.body.appendChild(ta); ta.select(); document.execCommand('copy'); document.body.removeChild(ta); copyBtn.textContent = '✅ Copied!'; setTimeout(() => { copyBtn.textContent = '📋 Copy'; }, 2000); }
    }
  });

  textarea?.addEventListener('input', function() { charCount.textContent = this.value.length + ' / 5000'; });
</script>
